{
    "name": "@frozencrow/api-core",
    "version": "0.2.1",
    "description": "Batteries-included Feathers 5 + Koa + MongoDB core: auth, RBAC, and multitenant access control",
    "license": "MIT",
    "author": "Eric Uldall",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Frozen-Crow/api-boilerplate.git",
        "directory": "packages/api-core"
    },
    "homepage": "https://github.com/Frozen-Crow/api-boilerplate#readme",
    "bugs": {
        "url": "https://github.com/Frozen-Crow/api-boilerplate/issues"
    },
    "keywords": [
        "feathers",
        "koa",
        "mongodb",
        "authentication",
        "rbac",
        "multitenant",
        "api"
    ],
    "engines": {
        "node": ">= 20.0.0"
    },
    "main": "lib/index.js",
    "types": "lib/index.d.ts",
    "bin": {
        "frozencrow": "cli/frozencrow.js"
    },
    "exports": {
        ".": {
            "types": "./lib/index.d.ts",
            "default": "./lib/index.js"
        },
        "./client": {
            "types": "./lib/client.d.ts",
            "default": "./lib/client.js"
        },
        "./declarations": {
            "types": "./lib/declarations.d.ts",
            "default": "./lib/declarations.js"
        },
        "./lib/declarations": {
            "types": "./lib/declarations.d.ts",
            "default": "./lib/declarations.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "lib",
        "cli"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "shx rm -rf lib/ && tsc && shx mkdir -p lib/utils/email-templates/templates && shx cp -r src/utils/email-templates/templates/* lib/utils/email-templates/templates/",
        "compile": "npm run build",
        "test": "cross-env NODE_ENV=test mocha test/ --require ts-node/register --recursive --extension .ts --exit",
        "prepublishOnly": "npm run build"
    },
    "dependencies": {
        "@feathersjs/adapter-commons": "^5.0.37",
        "@feathersjs/authentication": "^5.0.37",
        "@feathersjs/authentication-client": "^5.0.37",
        "@feathersjs/authentication-local": "^5.0.37",
        "@feathersjs/authentication-oauth": "^5.0.37",
        "@feathersjs/configuration": "^5.0.37",
        "@feathersjs/errors": "^5.0.37",
        "@feathersjs/feathers": "^5.0.37",
        "@feathersjs/koa": "^5.0.37",
        "@feathersjs/mongodb": "^5.0.37",
        "@feathersjs/schema": "^5.0.37",
        "@feathersjs/socketio": "^5.0.37",
        "@feathersjs/transport-commons": "^5.0.37",
        "@feathersjs/typebox": "^5.0.37",
        "dot": "^1.1.3",
        "feathers-hooks-common": "^8.2.1",
        "google-auth-library": "^8.9.0",
        "mongodb": "^6.21.0",
        "node-cache": "^5.1.2",
        "nodemailer": "^6.10.1",
        "qs": "^6.13.0",
        "winston": "^3.19.0"
    },
    "devDependencies": {
        "@types/dot": "^1.1.7",
        "@types/mocha": "^10.0.10",
        "@types/node": "^24.10.4",
        "@types/node-cache": "^4.1.3",
        "@types/nodemailer": "^7.0.5",
        "@types/qs": "^6.9.16",
        "cross-env": "^10.1.0",
        "mocha": "^11.7.5",
        "shx": "^0.4.0",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3"
    },
    "publishConfig": {
        "access": "public"
    }
}
